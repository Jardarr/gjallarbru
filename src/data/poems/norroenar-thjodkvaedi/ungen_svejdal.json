{
  "slug": "ungen-svejdal",
  "key": "UngenSvejdal",
  "title": {
    "on": "Ungen Svejdal",
    "ru": "Юный Свейдаль"
  },
  "subtitle": {
    "ru": "",
    "en": ""
  },
  "description": {
    "on": "",
