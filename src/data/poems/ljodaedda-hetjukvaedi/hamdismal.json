{
  "category": "ljodaedda-hetjukvaedi",
  "slug": "hamdismal",
  "key": "Hamdismal",
  "title": {
    "on": "Hamðismál",
    "ru": "Речи Хамдира",
    "en": "The Ballad of Hamdir"
  },
  "subtitle": {
    "on": "",
    "ru": ""
  },
  "description": {
    "on": "",
    "ru": "",
    "en": ""
  },
  "source": {
    "on": "",
    "ru": "Древнеисландский текст: Haraldur Bernharðsson. Текст на русском языке в переводе А. И. Корсуна, СЭ–1963, с. 154–157.",
    "en": "An ancient Icelandic text, edited by Haraldur Bernharðsson. Translation by Henry Adams Bellows."
  },
  "texts": {
    "on": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "Spruttu á tái",
          "tregnar íðir,",
          "græti álfa",
          "in glýstömu;",
          "ár um morgin",
          "manna bölva",
          "sútir hverjar",
          "sorg um kveykva."
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "Var a það nú",
          "né í gær,",
          "það hefir langt",
          "liðið síðan;",
          "er fátt fornara,",
          "fremr var það hálfu",
          "er hvatti Guðrún,",
          "Gjúka borin,",
          "sonu sína unga",
          "að hefna Svanhildar."
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "[Guðrún kvað:]",
          "Systir var ykkur",
          "Svanhildr um heitin,",
          "sú er Jörmunrekkr",
          "jóm um traddi,",
          "hvítum ok svörtum",
          "á hervegi,",
          "grám, gangtömum",
          "Gotna hrossum."
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "Eftir er ykkr þrungið",
          "þjóðkonunga,",
          "lifið einir ér þátta",
          "ættar minnar; ‖"
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "einstæð em ek orðin",
          "sem ösp í holti,",
          "fallin að frændum",
          "sem fura að kvisti,",
          "vaðin að vilja",
          "sem viðr að laufi,",
          "þá er in kvistskæða",
          "kjömr um dag varman.»"
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Hitt kvað þá Hamðir",
          "inn hugumstóri:",
          "«Lítt myndir þú þá, Guðrún,",
          "leyfa dáð Högna",
          "er þeir Sigurð",
          "svefni ór vökðu;"
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Bækr vóru þínar",
          "inar bláhvítu",
          "ofnar völundum,",
          "flutu í vers dreyra.",
          "Svalt þá Sigurðr,",
          "sazt u yfir dauðum,",
          "glýja þú né gáðir;",
          "Gunnarr þér svá vildi."
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Atla þóttiz þú stríða",
          "að Erps morði",
          "ok að Eitils aldrlagi,",
          "það var þér enn verra;",
          "svá skyldi hverr öðrum",
          "verja til aldrlaga",
          "sverði sárbeitu",
          "að sér né stríddi-t.»"
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Hitt kvað þá Sörli,",
          "svinna hafði hann hyggju:",
          "«Vil k at ek við móður",
          "málum skipta;",
          "orðs þikkir enn vant",
          "ykkru hváru;",
          "hvers biðr þú nú, Guðrún,",
          "er þú að gráti né fær-at?"
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Bræðr grát þú þína",
          "ok buri svása,",
          "niðja náborna",
          "leidda nær rógi;",
          "okkr skalt u ok, Guðrún,",
          "gráta báða",
          "er hér sitjum feigir á mörum,",
          "fjarri munum deyja.»"
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Gengu ór garði",
          "görvir að eiskra;",
          "liðu þá yfir ungir",
          "úrig fjöll",
          "mörum húnlenzkum,",
          "morðs að hefna."
        ],
        "placeholder": false
      },
      {
        "id": "12",
        "type": "stanza",
        "number": "12.",
        "lines": [
          "Þá kvað það Erpr",
          "einu sinni,",
          "mærr um lék",
          "á mars baki:",
          "Illt er blauðum hal",
          "brautir kenna;",
          "kóðu harðan mjök",
          "hornung vera."
        ],
        "placeholder": false
      },
      {
        "id": "13",
        "type": "stanza",
        "number": "13.",
        "lines": [
          "Fundu á stræti",
          "stórbrögðóttan:",
          "[Hamðir kvað:]",
          "«Hvé mun jarpskammr",
          "okkr fulltingja?»"
        ],
        "placeholder": false
      },
      {
        "id": "14",
        "type": "stanza",
        "number": "14.",
        "lines": [
          "Svaraði inn sundrmæðri,",
          "svá kvaz veita myndu",
          "fullting frændum",
          "sem fótr öðrum.",
          "[Hamðir kvað:]",
          "«Hvað megi fótr",
          "fæti veita",
          "né holdgróin",
          "hönd annarri?»"
        ],
        "placeholder": false
      },
      {
        "id": "15",
        "type": "stanza",
        "number": "15.",
        "lines": [
          "Drógu þeir ór skíði",
          "skíðijárn,",
          "mækis eggjar",
          "að mun flagði;",
          "þverrðu þeir þrótt sinn",
          "að þriðjungi,",
          "létu mög ungan",
          "til moldar hníga.."
        ],
        "placeholder": false
      },
      {
        "id": "16",
        "type": "stanza",
        "number": "16.",
        "lines": [
          "Skóku loða,",
          "skálmir festu",
          "ok goðbornir",
          "smugu í guðvefi;"
        ],
        "placeholder": false
      },
      {
        "id": "17",
        "type": "stanza",
        "number": "17.",
        "lines": [
          "fram lágu brautir,",
          "fundu vástigu",
          "ok systur son",
          "sáran á meiði,",
          "vargtré vindköld",
          "vestan bæjar;",
          "trýtti æ trönu hvöt,",
          "títt var að biðja."
        ],
        "placeholder": false
      },
      {
        "id": "18",
        "type": "stanza",
        "number": "18.",
        "lines": [
          "Glaumr var í höllu,",
          "halir ölreifir,",
          "ok til gota ekki",
          "gerðu t heyra",
          "áðr halr hugfullr",
          "í horn um þaut."
        ],
        "placeholder": false
      },
      {
        "id": "19",
        "type": "stanza",
        "number": "19.",
        "lines": [
          "Segja fóru",
          "Jörmunrekki",
          "að sénir vóru",
          "seggir undir hjálmum:",
          "«Ræðið ér um ráð!",
          "Ríkir eru komnir,",
          "fyr máttkum hafið ér mönnum",
          "mey um tradda.»"
        ],
        "placeholder": false
      },
      {
        "id": "20",
        "type": "stanza",
        "number": "20.",
        "lines": [
          "Hló þá Jörmunrekkr,",
          "hendi drap á kampa,",
          "beiddiz að bröngu,",
          "böðvaðiz að víni;",
          "skók hann skör jarpa,",
          "sá á skjöld hvítan,",
          "lét hann sér í hendi",
          "hvarfa ker gullið."
        ],
        "placeholder": false
      },
      {
        "id": "21",
        "type": "stanza",
        "number": "21.",
        "lines": [
          "[Jörmunrekkr kvað:]",
          "«Sæll ek þá þættumk",
          "ef ek sjá knætta",
          "Hamði ok Sörla",
          "í höllu minni;",
          "buri ‖ mynda ek þá binda",
          "með boga strengjum,",
          "góð börn Gjúka",
          "festa á gálga.»"
        ],
        "placeholder": false
      },
      {
        "id": "22",
        "type": "stanza",
        "number": "22.",
        "lines": [
          "Hitt kvað þá Hróðrglöð,",
          "stóð uf hléðum,",
          "mæfingr mælti",
          "við mög þenna:",
          "«Því að það heita",
          "að hlýði gi myni;",
          "mega tveir menn einir",
          "tíu hundruð Gotna",
          "binda eða berja",
          "í borg inni há?»"
        ],
        "placeholder": false
      },
      {
        "id": "23",
        "type": "stanza",
        "number": "23.",
        "lines": [
          "Styrr varð í ranni,",
          "stukku ölskálir,",
          "í blóði bragnar lágu,",
          "komið ór brjósti Gotna."
        ],
        "placeholder": false
      },
      {
        "id": "24",
        "type": "stanza",
        "number": "24.",
        "lines": [
          "Hitt kvað þá Hamðir",
          "inn hugumstóri:",
          "«Æstir, Jörmunrekr,",
          "okkarrar kvámu,",
          "bræðra sammæðra,",
          "innan borgar þinnar:",
          "fætr sér þú þína,",
          "höndum sér þú þínum,",
          "Jörmunrekr, orpið",
          "í eld heitan.»"
        ],
        "placeholder": false
      },
      {
        "id": "25",
        "type": "stanza",
        "number": "25.",
        "lines": [
          "Þá hraut við",
          "inn reginkunngi",
          "baldr í brynju",
          "sem björn hryti:",
          "«Grýtið ér á gumna",
          "allz geirar né bíta,",
          "eggjar né járn,",
          "Jónakrs sonu.»"
        ],
        "placeholder": false
      },
      {
        "id": "26",
        "type": "stanza",
        "number": "26.",
        "lines": [
          "Hitt kvað þá Hamðir",
          "inn hugumstóri:",
          "«Böl vannt u, bróðir,",
          "er þú þann belg leystir;",
          "oft ór þeim belg",
          "böll ráð koma.»"
        ],
        "placeholder": false
      },
      {
        "id": "27",
        "type": "stanza",
        "number": "27.",
        "lines": [
          "Sörli kvað:",
          "«Hug hefðir þú, Hamðir,",
          "ef þú hefðir hyggjandi,",
          "mikils er á mann hvern vant",
          "er manvits er.»"
        ],
        "placeholder": false
      },
      {
        "id": "28",
        "type": "stanza",
        "number": "28.",
        "lines": [
          "Hamðir kvað:",
          "«Af væri nú höfuð",
          "ef Erpr lifði,",
          "bróðir okkarr inn böðfrækni,",
          "er við á braut vágum,",
          "verr inn víðfrækni,",
          "hvöttu mk að dísir,",
          "gumi inn gunnhelgi,",
          "gjörðumz að vígi.»"
        ],
        "placeholder": false
      },
      {
        "id": "29",
        "type": "stanza",
        "number": "29.",
        "lines": [
          "Sörli kvað:",
          "«Ekki hygg ek okkr vera",
          "úlfa dæmi,",
          "að við mynim sjálfir um sakaz",
          "sem grey norna",
          "þau er gráðug eru",
          "í auðn um alin."
        ],
        "placeholder": false
      },
      {
        "id": "30",
        "type": "stanza",
        "number": "30.",
        "lines": [
          "Vel höfum við vegið,",
          "stöndum á val Gotna",
          "ofan eggmóðum",
          "sem ernir á kvisti;",
          "góðs höfum tírar fengið",
          "þótt skylim nú eða í gær deyja,",
          "kveld lifir maðr ekki",
          "eftir kvið norna.»"
        ],
        "placeholder": false
      },
      {
        "id": "31",
        "type": "stanza",
        "number": "31.",
        "lines": [
          "Þar fell Sörli",
          "að salar gafli",
          "en Hamðir hné",
          "að húsbaki."
        ],
        "placeholder": false
      },
      {
        "id": "32",
        "type": "prose",
        "lines": [
          "I Þetta eru kölluð Hamðis mál in fornu."
        ],
        "placeholder": false
      }
    ],
    "ru": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "Злые дела",
          "там свершились,",
          "когда наступило",
          "печальное утро;",
          "в утренний час",
          "черные мысли",
          "о бедах людских",
          "скорбны бывают!"
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "Не нынче то было",
          "и не вчера,",
          "это свершилось",
          "в давнее время,",
          "даже не в древности —",
          "в годы древнейшие;",
          "Гьюки рожденная",
          "Гудрун звала",
          "сынов отомстить",
          "за дочь свою Сванхильд."
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "[Гудрун сказала:]",
          "«Сванхильд — имя",
          "вашей сестры,",
          "что Ёрмунрекк бросил",
          "коням под копыта,",
          "вороным и белым,",
          "на дороге войны,",
          "серым, объезженным",
          "готским коням!"
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "Слава померкла",
          "конунгов рода!",
          "Одни вы в роду",
          "остались в живых."
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "Я одинока,",
          "что в роще осина,",
          "как сосна без ветвей,",
          "без близких живу я,",
          "счастья лишилась,",
          "как листьев дубрава,",
          "когда налетит",
          "ветер нежданно!»",
          "ты сидела на ложе,",
          "а убийцы смеялись."
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Хамдир сказал,",
          "духом отважный:",
          "«Не похвалила б ты",
          "подвига Хёгни,",
          "когда они Сигурда",
          "сон прервали,"
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Платки сине-белые,",
          "пестрые ткани",
          "багряными стали",
          "от крови супруга:",
          "Сигурд скончался,",
          "над ним ты сидела,",
          "горько скорбя, —",
          "в том Гуннар виновен!"
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Ты думала скорбь",
          "Атли доставить",
          "Эрпа убийством",
          "и смертью Эйтиля, —",
          "себе же на горе:",
          "разить неразумно",
          "острым мечом,",
          "коль сама себя ранишь!»"
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Мудрым был Сёрли,",
          "так он молвил:",
          "«Спорить не стану",
          "с матерью нашей,",
          "но одного",
          "вы еще не сказали:",
          "что просишь ты, Гудрун,",
          "беду накликая?"
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Братьев оплакивай,",
          "милых сынов,",
          "родичей близких,",
          "в битве погибших!",
          "Обоих нас тоже",
          "ты, Гудрун, оплачешь,",
          "всадников смелых! —",
          "к смерти мы близки»."
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Из дому вышли,",
          "фыркая в ярости,",
          "двинулись в путь",
          "через влажные горы",
          "на гуннских конях,",
          "к мести готовые."
        ],
        "placeholder": false
      },
      {
        "id": "12",
        "type": "stanza",
        "number": "12.",
        "lines": [
          "(14) Сказал тогда Эрп",
          "слова такие, —",
          "герой на коне",
          "возвышался, гарцуя:",
          "«Плохо дорогу",
          "показывать трусам!»",
          "«Очень уж смел",
          "ублюдок», — сказали."
        ],
        "placeholder": false
      },
      {
        "id": "13",
        "type": "stanza",
        "number": "13.",
        "lines": [
          "(12) Им повстречался",
          "хитрец по пути.",
          "[Хамдир сказал:]",
          "«Чем может помочь",
          "черныш в нашем деле?»"
        ],
        "placeholder": false
      },
      {
        "id": "14",
        "type": "stanza",
        "number": "14.",
        "lines": [
          "(13) Сводный брат обещал,",
          "что помощь окажет,",
          "как ноги друг другу",
          "идти помогают.",
          "[Хамдир сказал:]",
          "«Как может нога",
          "ноге быть в помощь",
          "и руки друг другу",
          "как пособят?»"
        ],
        "placeholder": false
      },
      {
        "id": "15",
        "type": "stanza",
        "number": "15.",
        "lines": [
          "Из ножен вынули",
          "ножен железо,",
          "взялись за мечи,",
          "великанше на радость:",
          "на треть у себя",
          "отняли силу —",
          "сразили юнца",
          "ударом смертельным."
        ],
        "placeholder": false
      },
      {
        "id": "16",
        "type": "stanza",
        "number": "16.",
        "lines": [
          "Встряхнули плащи,",
          "мечи прикрепили,",
          "оделись богато",
          "богорожденные."
        ],
        "placeholder": false
      },
      {
        "id": "17",
        "type": "stanza",
        "number": "17.",
        "lines": [
          "Нашли они путь —",
          "несчастья дорогу —",
          "и сына сестры",
          "под ветром студеным",
          "на древе казненных",
          "от двора на закат;",
          "мертвец качался, —",
          "там не было радостно."
        ],
        "placeholder": false
      },
      {
        "id": "18",
        "type": "stanza",
        "number": "18.",
        "lines": [
          "Весело пили",
          "воины в доме,",
          "за шумом не слышали",
          "стука копыт,",
          "пока им рогом",
          "не подали знака."
        ],
        "placeholder": false
      },
      {
        "id": "19",
        "type": "stanza",
        "number": "19.",
        "lines": [
          "Сказали тогда",
          "Ёрмунрекку,",
          "что стража увидела",
          "воинов в шлемах:",
          "«Обороняйтесь!",
          "Приехали сильные, —",
          "под копытами конскими",
          "погибла сестра их!»"
        ],
        "placeholder": false
      },
      {
        "id": "20",
        "type": "stanza",
        "number": "20.",
        "lines": [
          "Ёрмунрекк смелый",
          "в ответ усмехнулся,",
          "разгладил усы,",
          "не взялся за меч,",
          "",
          "вином возбужденный,",
          "тряхнул волосами,",
          "на щит поглядел,",
          "кубком играя",
          "из золота жаркого."
        ],
        "placeholder": false
      },
      {
        "id": "21",
        "type": "stanza",
        "number": "21.",
        "lines": [
          "[Ёрмунрекк сказал:]",
          "«Счастлив я был бы",
          "Сёрли и Хамдира",
          "видеть в палатах,",
          "принять их обоих:",
          "связал бы я сразу",
          "сынков тетивами,",
          "им петли на шеи",
          "обоим накинул бы!»"
        ],
        "placeholder": false
      },
      {
        "id": "22",
        "type": "stanza",
        "number": "22.",
        "lines": [
          "Молвила славная,",
          "стоя с героями,",
          "так говорила",
          "этому юноше:",
          "[непонятное",
          "место — прим. перев.] 8",
          "могут ли двое",
          "тысячу готов",
          "связать иль побить",
          "в высоких палатах?»"
        ],
        "placeholder": false
      },
      {
        "id": "23",
        "type": "stanza",
        "number": "23.",
        "lines": [
          "Шум поднялся.",
          "падали чаши,",
          "ступали герои",
          "по крови готов."
        ],
        "placeholder": false
      },
      {
        "id": "24",
        "type": "stanza",
        "number": "24.",
        "lines": [
          "Вымолвил Хамдир,",
          "духом отважный:",
          "«Ждал ты нас, Ёрмунрекк,",
          "видеть желал нас,",
          "братьев принять",
          "в высоких палатах:",
          "вот ноги твои",
          "и руки твои,",
          "Ёрмунрекк, брошены",
          "в жаркий огонь!»"
        ],
        "placeholder": false
      },
      {
        "id": "25",
        "type": "stanza",
        "number": "25.",
        "lines": [
          "Рычаньем ответил",
          "богами рожденный,",
          "конунг в кольчуге,",
          "как ярый медведь:",
          "«Бросайте в них камни,",
          "ни копья, ни лезвия",
          "их не разят —",
          "отпрысков Йонакра!»"
        ],
        "placeholder": false
      },
      {
        "id": "26",
        "type": "stanza",
        "number": "26.",
        "lines": [
          "Вымолвил Хамдир,",
          "духом отважный:",
          "«Ты злое свершил,",
          "этот мех развязав,",
          "извергает он часто",
          "речи опасные!»"
        ],
        "placeholder": false
      },
      {
        "id": "27",
        "type": "stanza",
        "number": "27.",
        "lines": [
          "[Сёрли сказал:]",
          "«Ты, Хамдир, смел,",
          "да смышленым ты не был —",
          "обездолены те,",
          "в ком ума не хватает!»"
        ],
        "placeholder": false
      },
      {
        "id": "28",
        "type": "stanza",
        "number": "28.",
        "lines": [
          "[Хамдир сказал:]",
          "«Голова бы скатилась.",
          "будь Эрп в живых,",
          "смелый наш брат,",
          "нами убитый,",
          "воинственный муж,",
          "дисы вмешались,",
          "хранимого в битвах",
          "стремясь уничтожить!»"
        ],
        "placeholder": false
      },
      {
        "id": "29",
        "type": "stanza",
        "number": "29.",
        "lines": [
          "[Сёрли сказал:]",
          "«Волки для нас",
          "недобрый пример —",
          "грызться не будем,",
          "как норн злые псы,",
          "что вражды не таят,",
          "вырастая в пустыне!"
        ],
        "placeholder": false
      },
      {
        "id": "30",
        "type": "stanza",
        "number": "30.",
        "lines": [
          "Мы стойко бились, —",
          "на трупах врагов",
          "мы — как орлы",
          "на сучьях древесных!",
          "Со славой умрем",
          "сегодня иль завтра, —",
          "никто не избегнет",
          "норн приговора!»"
        ],
        "placeholder": false
      },
      {
        "id": "31",
        "type": "stanza",
        "number": "31.",
        "lines": [
          "Сёрли погиб",
          "у торцовой стены,",
          "у задней стены",
          "был Хамдир сражен."
        ],
        "placeholder": false
      },
      {
        "id": "32",
        "type": "prose",
        "lines": [
          "I Это называется Древние Речи Хамдира."
        ],
        "placeholder": false
      }
    ],
    "en": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "\"Great the evils",
          "once that grew,",
          "With the dawning sad",
          "of the sorrow of elves;",
          "In early mom",
          "awake for men",
          "The evils that grief",
          "to each shall bring.\""
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "\"Not now, nor yet",
          "of yesterday was it,",
          "Long the time",
          "that since hath lapsed,",
          "So that little there is",
          "that is half as old,",
          "Since Guthrun, daughter",
          "of Gjuki, whetted",
          "Her sons so young",
          "to Svanhild's vengeance.\""
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "\"The sister ye had",
          "was Svanhild called,",
          "And her did Jormunrek",
          "trample with horses,",
          "White and black",
          "on the battle-way,",
          "Gray, road-wonted,",
          "the steeds of the Goths.\""
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "\"Little the kings",
          "of the folk are ye like,",
          "For now ye are living",
          "alone of my race.\""
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "\"Lonely am I",
          "as the forest aspen,",
          "Of kindred bare",
          "as the fir of its boughs,",
          "My joys are all lost",
          "as the leaves of the tree",
          "When the scather of twigs",
          "from the warm day turns.\""
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Then Hamther spake forth,",
          "the high of heart:",
          "\"Small praise didst thou, Guthrun,",
          "to Hogni's deed give",
          "When they wakened thy Sigurth",
          "from out of his sleep,",
          "Thou didst sit on the bed",
          "while his slayers laughed.\""
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "\"Thy bed-covers white",
          "with blood were red",
          "From his wounds, and with gore",
          "of thy husband were wet;",
          "So Sigurth was slain,",
          "by his corpse didst thou sit,",
          "And of gladness didst think not:",
          "twas Gunnar's doing.\""
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "\"Thou wouldst strike at Atli",
          "by the slaying of Erp",
          "And the killing of Eitil;",
          "thine own grief was worse;",
          "So should each one wield",
          "the wound-biting sword",
          "That another it slays",
          "but smites not himself.\""
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Then did Sorli speak out,",
          "for wise was he ever:",
          "\"With my mother I never",
          "a quarrel will make;",
          "Full little in speaking",
          "methinks ye both lack;",
          "What askest thou, Guthrun,",
          "that will give thee no tears?\""
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "\"For thy brothers dost weep,",
          "and thy boys so sweet,",
          "Thy kinsmen in birth",
          "on the battlefield slain;",
          "Now, Guthrun, as; well",
          "for us both shalt thou weep,",
          "We sit doomed on our steeds,",
          "and far hence shall we die.\""
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Then the fame-glad one",
          "on the steps she was",
          "The slender-fingered,",
          "spake with her son:",
          "\"Ye shall danger have",
          "if counsel ye heed not;",
          "By two heroes alone",
          "shall two hundred of Goths",
          "Be bound or be slain",
          "in the lofty-walled burg.\""
        ],
        "placeholder": false
      },
      {
        "id": "12",
        "type": "stanza",
        "number": "12.",
        "lines": [
          "\"From the courtyard they fared,",
          "and fury they breathed;",
          "The youths swiftly went",
          "o'er the mountain wet,",
          "On their Hunnish steeds,",
          "death's vengeance to have.\""
        ],
        "placeholder": false
      },
      {
        "id": "13",
        "type": "stanza",
        "number": "13.",
        "lines": [
          "\"On the way they found",
          "the man so wise;",
          "*********",
          "What help from the weakling",
          "brown may we have?\""
        ],
        "placeholder": false
      },
      {
        "id": "14",
        "type": "stanza",
        "number": "14.",
        "lines": [
          "So answered them",
          "their half-brother then:",
          "\"So well may I",
          "my kinsmen aid",
          "As help one foot",
          "from the other has.\""
        ],
        "placeholder": false
      },
      {
        "id": "15",
        "type": "stanza",
        "number": "15.",
        "lines": [
          "\"How may afoot",
          "its fellow aid,",
          "Or a flesh-grown hand",
          "another help?\""
        ],
        "placeholder": false
      },
      {
        "id": "16",
        "type": "stanza",
        "number": "16.",
        "lines": [
          "\"Then Erp spake forth,",
          "his words were few,",
          "As haughty he sat",
          "on his horse's back:",
          "To the timid tis ill",
          "the way to tell.",
          "A bastard they",
          "the bold one called.\""
        ],
        "placeholder": false
      },
      {
        "id": "17",
        "type": "stanza",
        "number": "17.",
        "lines": [
          "\"From their sheaths they drew",
          "their shining swords,",
          "Their blades, to the giantess",
          "joy to give;",
          "By a third they lessened",
          "the might that was theirs,",
          "The fighter young",
          "to earth they felled.\""
        ],
        "placeholder": false
      },
      {
        "id": "18",
        "type": "stanza",
        "number": "18.",
        "lines": [
          "\"Their cloaks they shook,",
          "their swords they sheathed,",
          "The high-born men",
          "wrapped their mantles close.\""
        ],
        "placeholder": false
      },
      {
        "id": "19",
        "type": "stanza",
        "number": "19.",
        "lines": [
          "\"On their road they fared",
          "and an ill way found,",
          "And their sister's son",
          "on a tree they saw,",
          "On the wind-cold wolf-tree",
          "west of the hall,",
          "And cranes'-bait crawled;",
          "none would care to linger.\""
        ],
        "placeholder": false
      },
      {
        "id": "20",
        "type": "stanza",
        "number": "20.",
        "lines": [
          "\"In the hall was din,",
          "the men drank deep,",
          "And the horses' hoofs",
          "could no one hear,",
          "Till the warrior hardy",
          "sounded his horn\""
        ],
        "placeholder": false
      },
      {
        "id": "21",
        "type": "stanza",
        "number": "21.",
        "lines": [
          "Men came and the tale",
          "to Jormunrek told",
          "How warriors helmed",
          "without they beheld:",
          "\"Take counsel wise,",
          "for brave ones are come,",
          "Of mighty men",
          "thou the sister didst murder.\""
        ],
        "placeholder": false
      },
      {
        "id": "22",
        "type": "stanza",
        "number": "22.",
        "lines": [
          "\"Then Jormunrek laughed,",
          "his hand laid on his beard,",
          "His arms, for with wine",
          "he was warlike, he called for;",
          "He shook his brown locks,",
          "on his white shield he looked,",
          "And raised high the cup",
          "of gold in his hand.\""
        ],
        "placeholder": false
      },
      {
        "id": "23",
        "type": "stanza",
        "number": "23.",
        "lines": [
          "\"Happy, methinks,",
          "were I to behold",
          "Hamther and Sorli",
          "here in my hall;",
          "The men would I bind",
          "with strings of bows,",
          "And Gjuki's heirs",
          "on the gallows hang.\""
        ],
        "placeholder": false
      },
      {
        "id": "24",
        "type": "stanza",
        "number": "24.",
        "lines": [
          "\"In the hall was clamor,",
          "the cups were shattered,",
          "Men stood in blood",
          "from the breasts of the Goths,\""
        ],
        "placeholder": false
      },
      {
        "id": "25",
        "type": "stanza",
        "number": "25.",
        "lines": [
          "Then did Hamther speak forth,",
          "the haughty of heart:",
          "\"Thou soughtest, Jormunrek,",
          "us to see,",
          "Sons of one mother",
          "seeking thy dwelling;",
          "Thou seest thy hands,",
          "thy feet thou beholdest,",
          "Jormunrek, flung",
          "in the fire so hot.\""
        ],
        "placeholder": false
      },
      {
        "id": "26",
        "type": "stanza",
        "number": "26.",
        "lines": [
          "Then roared the king,",
          "of the race of the gods,",
          "Bold in his armor,",
          "as roars a bear:",
          "\"Stone ye the men",
          "that steel will bite not,",
          "Sword nor spear,",
          "the sons of Jonak.\""
        ],
        "placeholder": false
      },
      {
        "id": "27",
        "type": "stanza",
        "number": "27.",
        "lines": [
          "Sorli spake:",
          "\"Ill didst win, brother,",
          "when the bag thou didst open,",
          "Oft from that bag",
          "came baleful counsel;",
          "Heart hast thou, Hamther,",
          "if knowledge thou hadst!",
          "A man without wisdom",
          "is lacking in much.\""
        ],
        "placeholder": false
      },
      {
        "id": "28",
        "type": "stanza",
        "number": "28.",
        "lines": [
          "Hamther spake:",
          "\"His head were now off",
          "if Erp were living,",
          "The brother so keen",
          "whom we killed on our road,",
          "The warrior noble,",
          "twas the Norns that drove me",
          "The hero to slay",
          "who in fight should be holy.\""
        ],
        "placeholder": false
      },
      {
        "id": "29",
        "type": "stanza",
        "number": "29.",
        "lines": [
          "\"In fashion of wolves",
          "it befits us not",
          "Amongst ourselves to strive,",
          "Like the hounds of the Norns,",
          "that nourished were",
          "In greed mid wastes so grim.\""
        ],
        "placeholder": false
      },
      {
        "id": "30",
        "type": "stanza",
        "number": "30.",
        "lines": [
          "\"We have greatly fought,",
          "o'er the Goths do we stand",
          "By our blades laid low,",
          "like eagles on branches;",
          "Great our fame though we die",
          "today or tomorrow;",
          "None outlives the night",
          "when the Norris have spoken.\""
        ],
        "placeholder": false
      },
      {
        "id": "31",
        "type": "stanza",
        "number": "31.",
        "lines": [
          "\"Then Sorli beside",
          "the gable sank,",
          "And Hamther fell",
          "at the back of the house.\""
        ],
        "placeholder": false
      },
      {
        "id": "32",
        "type": "prose",
        "lines": [
          "This is called the old ballad of Hamther."
        ],
        "placeholder": false
      }
    ]
  }
}