        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Without stood Guthrun,",
          "Gjuki's daughter,",
          "Hear now the speech",
          "that first she spake:",
          "\"Where is Sigurth now,",
          "the noble king,",
          "That my kinsmen riding",
          "before him come?\""
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Only this",
          "did Hogni answer:",
          "\"Sigurth we",
          "with our swords have slain;",
          "The gray horse mourns",
          "by his master dead.\""
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Then Brynhild spake,",
          "the daughter of Buthli:",
          "\"Well shall ye joy",
          "in weapons and lands;",
          "Sigurth alone",
          "of all had been lord,",
          "If a little longer",
          "his life had been.\""
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "\"Right were it not",
          "that so he should rule",
          "O'er Gjuki's wealth",
          "and the race of the Goths;",
          "Five are the sons",
          "for ruling the folk,",
          "And greedy of fight,",
          "that he hath fathered.\""
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Then Brynhild laughed",
          "and the building echoed",
          "Only once,",
          "with all her heart;",
          "\"Long shall ye joy",
          "in lands and men,",
          "Now ye have slain",
          "the hero noble.,\""
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
