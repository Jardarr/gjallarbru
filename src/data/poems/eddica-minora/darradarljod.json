  "source": {
    "on": "",
    "ru": "Древнеисландский текст: Njáls saga — Íslendinga sögur. Guðni Jónsson bjó til prentunar. Текст на русском языке в переводе А. И. Корсунан, СЭ–1963, с. 172–173.",
    "en": "An ancient Icelandic text, Njáls saga — Íslendinga sögur. Guðni Jónsson bjó til prentunar. Translation by George W. DaSent (1861)."
  },
  "texts": {
    "on": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "Vítt es orpit",
          "fyr valfalli",
          "rifs reiðiský.",
          "Rignir blóði.",
          "Nú es fyr geirum",
          "grár upp kominn",
          "vefr, verþjóðar",
          "sás vinur fylla",
          "rauðum vefti",
          "Randvés bana."
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "Sjá es orpinn vefr",
          "ýta þörmum",
          "ok harðkléaðr",
          "höfðum manna.",
          "Eru dreyrrekin",
          "dörr at sköftum",
          "járnvarðr yllir,",
          "en örum hrælaðr.",
          "Skulum slá sverðum",
          "sigrvef þenna."
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "Gengr Hildr vefa",
          "ok Hjörþrimul,",
          "Sanngríðr, Svipul",
          "sverðum tognum.",
          "Skaft mun gnesta",
          "skjöldr mun bresta,",
          "mun hjalmgagarr",
          "í hlíf koma."
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "Vindum, vindum",
          "vef Darraðar,",
          "þanns ungr konungr",
          "átti fyrri.",
          "Fram skulum ganga",
          "ok í folk vaða,",
          "þars vinir órir",
          "vápnum skipta."
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "Vindum, vindum",
          "vef Darraðar",
          "ok siklingi",
          "síðan fylgjum.",
          "Þar séa bragna",
          "blóðgar randir",
          "Gunnr ok Göndul,",
          "þærs grami fylgðu."
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Vindum, vindum",
          "vef Darraðar,",
          "þars vé vaða",
          "vígra manna.",
          "Látum eigi",
          "líf hans farask.",
          "Eigu valkyrjur",
          "vals of kosti."
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Þeir munu lýðir",
          "löndum ráða,",
          "es útskaga",
          "áðr of byggðu.",
          "Kveðk ríkjum gram",
          "ráðinn dauða.",
          "Nú es fyr oddum",
          "jarlmaðr hniginn."
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Ok munu Írar",
          "angr of bíða,",
          "þats aldri mun",
          "ýtum fyrnask.",
          "Nú es vefr ofinn,",
          "en völlr roðinn.",
          "Munu of lönd fara",
          "læspjöll gota."
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Nú es ógurligt",
          "umb at lítask,",
          "es deyrug ský",
          "dregr með himni.",
          "Mun loft litat",
          "lýða blóði",
          "es sóknvarðir",
          "syngva kunnu."
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Vel kváðum vér",
          "of konung ungan",
          "sighljóða fjölð.",
          "Syngum heilar.",
          "En hinn nemi,",
          "es heyrir á,",
          "geirfljóða hljóð",
          "ok gumum segi."
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Ríðum hestum",
          "hart út berum",
          "brugðnum sverðum",
          "á braut heðan."
        ],
        "placeholder": false
      }
    ],
    "ru": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "Туго натянута",
          "ткани основа",
          "и смерть предвещает,",
          "хлынула кровь;",
          "вот появился",
          "из копий стальных",
          "ткани уток,",
          "он будет наполнен",
          "красною пряжей",
          "убийцы Рандвера."
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "Ткани основа —",
          "кишки человечьи;",
          "вместо грузил",
          "на станке — черепа,",
          "а перекладины —",
          "копья в крови,",
          "бёрдо — железное,",
          "стрелы — челнок;",
          "будем мечами",
          "ткань подбивать!"
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "Хьёртримуль, Хильд.",
          "Саннгрид и Свипуль,",
          "мечи обнажив,",
          "начали ткать;",
          "сломятся копья,",
          "треснут щиты,",
          "если псы шлема",
          "вцепятся в них."
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "Мы ткём, мы ткём",
          "стяг боевой;",
          "был он в руках",
          "у конунга юного;",
          "выйдем вперёд,",
          "ринемся в бой,",
          "где наши друзья",
          "удары наносят!"
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "Мы ткём, мы ткём",
          "стяг боевой;",
          "конунгу вслед",
          "пора нам скакать!",
          "Гёндуль и Гунн",
          "за ним помчались,",
          "кровь на щитах",
          "увидят они."
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Мы ткём, мы ткём",
          "стяг боевой;",
          "рвутся вперёд",
          "смелые воины.",
          "Конунга жизнь",
          "мы защитим, —",
          "нам выбирать,",
          "кто в сече погибнет."
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Будут землёй",
          "люди владеть,",
          "что жили досель",
          "на дальних мысах;",
          "могучему конунгу",
          "смерть суждена;",
          "славного ярла",
          "копья пронзят."
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Ирам готов",
          "горький удел,",
          "память о нём",
          "вечною будет;",
          "соткана ткань,",
          "поле боя в крови;",
          "о мертвых по свету",
          "молва прошумит."
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Страшно теперь",
          "оглянуться: смотри!",
          "По небу мчатся",
          "багровые тучи;",
          "воинов кровь",
          "окрасила воздух, —",
          "только валькириям",
          "это воспеть!"
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Спели мы славно",
          "о конунге юном;",
          "слава поющим!",
          "Слышавший нас",
          "песню запомнит,",
          "людям расскажет",
          "о том, что слышал",
          "от жен копьеносных!"
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Мечи обнажив,",
          "на диких конях,",
          "не знающих седел,",
          "прочь мы умчимся."
        ],
        "placeholder": false
      }
    ],
    "en": [
      {
        "id": "1",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "\"See! warp is stretched",
          "For warriors' fall,",
          "Lo! weft in loom",
          "Tis wet with blood;",
          "Now fight foreboding,",
          "Neath friends swift fingers,",
          "Our gray woof waxeth",
          "With war's alarms,",
          "Our warp bloodred,",
          "Our weft corseblue.\""
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "\"This woof is y-woven",
          "With entrails of men,",
          "This warp is hardweighted",
          "With heads of the slain,",
          "Spears blood-besprinkled",
          "For spindles we use,",
          "Our loom ironbound,",
          "And arrows our reels;",
          "With swords for our shuttles",
          "This war-woof we work;",
          "So weave we, weird sisters,",
          "Our warwinning woof.\""
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "\"Now War-winner walketh",
          "To weave in her turn.",
          "Now Swordswinger steppeth,",
          "Now Swiftstroke, now Storm;",
          "When they speed the shuttle",
          "How spear-heads shall flash!",
          "Shields crash, and helmgnawerö",
          "On harness bite hard!\""
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "\"Wind we, wind swiftly",
          "Our warwinning woof.",
          "Woof erst for king youthful",
          "Foredoomed as his own,",
          "Forth now we will ride,",
          "Then through the ranks rushing",
          "Be busy where friends",
          "Blows blithe give and take.\""
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "\"Wind we, wind swiftly",
          "Our warwinning woof,",
          "After that let us steadfastly",
          "Stand by the brave king;",
          "Then men shall mark mournful",
          "Their shields red with gore,",
          "How Swordstroke and Spearthrust",
          "Stood stout by the prince.\""
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "\"Wind we, wind swiftly",
          "Our warwinning woof;",
          "When sword-bearing rovers",
          "To banners rush on,",
          "Mind, maidens, we spare not",
          "One life in the fray!",
          "We corse-choosing sisters",
          "Have charge of the slain.\""
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "\"Now new-coming nations",
          "That island shall rule.",
          "Who on outlying headlands",
          "Abode ere the fight;",
          "I say that King mighty",
          "To death now is done,",
          "Now low before spearpoint",
          "That Earl bows his head.\""
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "\"Soon over all Ersemen",
          "Sharp sorrow shall fall,",
          "That woe to those warriors",
          "Shall wane nevermore;",
          "Our woof now is woven.",
          "Now battle-field waste,",
          "O'er land and o'er water",
          "War tidings shall leap.\""
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "\"Now surely tis gruesome",
          "To gaze all around,",
          "When bloodred through heaven",
          "Drives cloudrack o'er head;",
          "Air soon shall be deep hued",
          "With dying men's blood",
          "When this our spaedom",
          "Comes speedy to pass.\""
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "\"So cheerily chant we",
          "Charms for the young king,",
          "Come maidens lift loudly",
          "His warwinning lay;",
          "Let him who now listens",
          "Learn well with his ears,",
          "And gladden brave swordsmen",
          "With bursts of war's song.\""
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "\"Now mount we our horses,",
          "Now bare we our brands,",
          "Now haste we hard, maidens,",
          "Hence far, far away.\""
        ],
        "placeholder": false
      }
    ]
  }
}