{
  "category": "eddica-minora",
  "slug": "darradarljod",
  "key": "Darradarljod",
  "title": {
    "on": "Darraðarljóð",
    "ru": "Песнь валькирий",
    "en": "Song of Dorrud"
  },
  "subtitle": {
    "on": "",
    "ru": ""
  },
  "description": {
    "on": "",
    "ru": "",
