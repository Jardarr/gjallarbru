        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "h ᚻ  Hægl býþ hwitust corna ·",
          "ᚼ hwýrft hit of heofones lýfte ·",
