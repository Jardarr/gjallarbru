      {
        "id": "2",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "f ᚠ Feoh býþ frofur ·",
          "fira gehwýlcum ·",
          "sceal ðeah manna gehwýlc ·",
          "miclun hýt dælan ·",
          "gif he wile ·",
          "for drihtne domes hleotan :·"
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "u ᚢ Ur býþ anmod ·",
          "ond oferhýrned ·",
          "felafrecne · deor",
          "feohteþ · mid hornum",
          "mære morstapa ·",
          "þæt is modig wuht :·"
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "ð ᚦ Ðorn býþ ðearle scearp ·",
