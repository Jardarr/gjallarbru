          "ðær hi æþelingas",
          "inne restaþ :·"
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "ᵹ ᚷ Gyfu gumena býþ",
