        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "r ᚱ Rad býþ on recýde ·",
          "rinca gehwýlcum ·",
          "sefte and swiþhwæt ·",
          "ðamðe sitteþ on ufan ·",
          "meare mægenheardum ·",
