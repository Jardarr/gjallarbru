          "wexeð on wature",
          "wundaþ grimme ·",
          "blode breneð",
          "beorna gehwýlcne ·",
          "ðe him ænigne",
          "onfeng gedeþ :·"
        ],
        "placeholder": false
      },
      {
        "id": "18",
        "type": "stanza",
        "number": "16.",
        "lines": [
          "s ᛋ Sigel semannum",
          "sýmble biþ on hihte",
          "ðonne hi hine feriaþ",
          "ofer fisces beþ",
          "oþ hi brimhengest",
          "bringeþ to lande :·"
        ],
        "placeholder": false
