        ],
        "placeholder": false
      },
      {
        "id": "20",
        "type": "stanza",
        "number": "17.",
        "lines": [
          "t ᛏ Tir biþ tacna sum",
          "healdeð trýwa wel ·",
          "wiþ æþelingas",
          "a biþ on færýlde ·",
          "ofer nihta genipu ·",
          "næfre swiceþ :·"
        ],
        "placeholder": false
      },
      {
        "id": "21",
        "type": "stanza",
        "number": "18.",
        "lines": [
          "b ᛒ Beorc býþ bleda leas ·",
          "bereþ efne swa ðeah",
          "tanas butan tudder ·",
          "biþ on telgum wlitig ·",
          "heah on helme",
          "hrýsted fægere ·",
          "geloden leafum",
          "lýfte getenge :·"
        ],
        "placeholder": false
      },
      {
        "id": "22",
        "type": "stanza",
        "number": "19.",
        "lines": [
          "e ᛖ Eh býþ for eorlum",
          "æþelinga wýn ·",
          "hors hofum wlanc ·",
          "ðær him hæleþ ýmb[e] ·",
          "welege on wicgum",
          "wrixlaþ spræce ·",
          "and biþ unstýllum",
          "æfre frofur :·"
        ],
        "placeholder": false
      },
      {
        "id": "23",
        "type": "stanza",
        "number": "20.",
        "lines": [
          "m ᛗ Man býþ on mýrgþe",
          "his magan leof:",
          "sceal þeah anra gehwýlc",
          "oðrum swican ·",
          "forðum drihten wýle ·",
          "dome sine",
          "þæt earme flæsc ·",
          "eorþan betæcan :·"
        ],
        "placeholder": false
      },
      {
        "id": "24",
        "type": "stanza",
        "number": "21.",
        "lines": [
          "l ᛚ Lagu býþ leodum",
          "langsum geþuht,",
          "gif hi sculun neþan",
          "on nacan tealtum ·",
          "and hi sæýþa",
          "swýþe bregaþ ·",
          "and se brimhengest",
          "bridles ne gým[eð] :·"
        ],
        "placeholder": false
      },
      {
        "id": "25",
        "type": "stanza",
        "number": "22.",
        "lines": [
          "ŋ ᛝ Ing wæs ærest",
          "mid east denum ·",
          "gesewen secgun ·",
          "oþ he siððan est ·",
          "ofer wæg gewat",
          "wæn æfter ran ·",
          "ðus heardingas",
          "ðone hæle nemdun"
        ],
        "placeholder": false
      },
      {
        "id": "26",
        "type": "stanza",
        "number": "23.",
        "lines": [
          "œ ᛟ Eþel býþ oferleof ·",
          "æghwýlcum men ·",
          "gif he mot ðær · rihtes",
          "and gerýsena on",
          "brucan on bolde",
          "bleadum oftast :·"
        ],
        "placeholder": false
      },
      {
        "id": "27",
        "type": "stanza",
        "number": "24.",
        "lines": [
          "d ᛞ Dæg býþ drihtnes sond ·",
          "deore mannum ·",
          "mære metodes leoht ·",
          "mýrgþ and tohiht",
          "eadgum and earmum ·",
          "eallum brice :·"
        ],
        "placeholder": false
      },
      {
        "id": "28",
        "type": "heading",
        "lines": [
          "Att IV"
        ],
        "placeholder": false
      },
      {
        "id": "29",
        "type": "stanza",
        "number": "25.",
        "lines": [
          "a ᚪ Ac býþ on eorþan ·",
          "elda bearnum ·",
          "flæsces fodor",
          "fereþ gelome",
          "ofer ganotes bæþ",
          "garsecg fandaþ ·",
          "hwæþer ac hæbbe",
          "æþele treowe :·"
        ],
        "placeholder": false
      },
      {
        "id": "30",
        "type": "stanza",
        "number": "26.",
        "lines": [
          "æ ᚫ Æsc biþ oferheah ·",
          "eldum dýre ·",
          "stiþ on staþule ·",
          "stede rihte hýlt ·",
          "ðeah him feohtan on",
          "firas monige :·"
        ],
        "placeholder": false
      },
      {
        "id": "31",
        "type": "stanza",
        "number": "27.",
        "lines": [
          "ý ᚣ Ýr býþ æþelinga",
          "and eorla gehwæs ·",
          "wýn and wýrþmýnd ·",
          "býþ on wicge fæger",
          "fæstlic on færelde ·",
          "fýrdgeatewa sum :·"
        ],
        "placeholder": false
      },
      {
        "id": "32",
        "type": "stanza",
        "number": "28.",
        "lines": [
          "io ᛡ Ior býþ eafix",
          "and ðeah a bruceþ ·",
          "fodres on foldan ·",
          "hafaþ fægerne eard ·",
          "wætre beworpen",
          "ær he wýnnum leofaþ :·"
        ],
        "placeholder": false
      },
      {
        "id": "33",
        "type": "stanza",
        "number": "29.",
        "lines": [
          "ea ᛠ Ear býþ egle",
          "eorla gehwýlcun",
          "ðonn[e] fæstlice",
          "flæsc onginneþ",
          "hraw colian",
          "hrusan ceosan",
          "blac to gebeddan",
          "bleda gedreosaþ",
          "wýnna gewitaþ",
          "wera geswicaþ"
        ],
