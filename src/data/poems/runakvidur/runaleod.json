    ],
    "ru": [
      {
        "id": "1",
        "type": "heading",
        "lines": [
          "Att I"
        ],
        "placeholder": false
      },
      {
        "id": "2",
        "type": "stanza",
        "number": "1.",
        "lines": [
          "Богатство — утешение",
          "всем людям,",
          "но должен человек каждый —",
          "щедро им делиться,",
          "если он хочет",
          "перед Господом славу обрести."
        ],
        "placeholder": false
      },
      {
        "id": "3",
        "type": "stanza",
        "number": "2.",
        "lines": [
          "Тур яр",
          "и великорог,",
          "свирепейший зверь,",
          "сражается рогами",
          "прославленный скиталец пустошей.",
          "Это отважное существо"
        ],
        "placeholder": false
      },
      {
        "id": "4",
        "type": "stanza",
        "number": "3.",
        "lines": [
          "Шип (терн?) — жестоко остр,",
          "тану каждому",
          "схватившемуся — он зло,",
          "безмерно суров",
          "к человеку любому,",
          "что на нем отдыхает."
        ],
        "placeholder": false
      },
      {
        "id": "5",
        "type": "stanza",
        "number": "4.",
        "lines": [
          "Бог (Ас) — источник (князь)",
          "всей речи,",
          "опора мудрости",
          "и утешение мудрецам,",
          "и каждому эрлу —",
          "благо и надежда."
        ],
        "placeholder": false
      },
      {
        "id": "6",
        "type": "stanza",
        "number": "5.",
        "lines": [
          "Верховая езда в чертоге",
          "воину каждому",
          "сладка, и тяжка",
          "для того, кто сидя на",
          "коне могучем,",
          "в многомильном пути."
        ],
        "placeholder": false
      },
      {
        "id": "7",
        "type": "stanza",
        "number": "6.",
        "lines": [
          "Факел всем живым существам",
          "известен огнем",
          "яркий и ясный —",
          "горит чаще всего",
          "там, где этелинги",
          "отдыхают дома."
        ],
        "placeholder": false
      },
      {
        "id": "8",
        "type": "stanza",
        "number": "7.",
        "lines": [
          "Дар для людей —",
          "честь и хвала,",
          "поддержка и почет,",
          "и бродяге любому",
          "милость и средства к существованию,",
          "которых иначе он лишен."
        ],
        "placeholder": false
      },
      {
        "id": "9",
        "type": "stanza",
        "number": "8.",
        "lines": [
          "Радостью наслаждается тот,",
          "кто знает мало бед,",
          "страданий и тревог.",
          "И сам имеет",
          "процветание и блаженство",
          "и достаточно крепкую обитель."
        ],
        "placeholder": false
      },
      {
        "id": "10",
        "type": "heading",
        "lines": [
          "Att II"
        ],
        "placeholder": false
      },
      {
        "id": "11",
        "type": "stanza",
        "number": "9.",
        "lines": [
          "Град — белейшее зерно,",
          "выпадает оно с небесной выси,",
          "мечут его бури с ливнями,",
          "обращается оно в воду затем."
        ],
        "placeholder": false
      },
      {
        "id": "12",
        "type": "stanza",
        "number": "10.",
        "lines": [
          "Нужда тесна на груди,",
          "но становится она часто",
          "сынам человеческим",
          "и в помощь, и в спасение — если",
          "она услышана заранее."
        ],
        "placeholder": false
      },
      {
        "id": "13",
        "type": "stanza",
        "number": "11.",
        "lines": [
          "Лед очень холоден,",
          "безмерно скользок,",
          "сияет ясным стеклом,",
          "подобно драгоценностям,",
          "настил, морозом созданный,",
          "прекрасен видом."
        ],
        "placeholder": false
      },
      {
        "id": "14",
        "type": "stanza",
        "number": "12.",
        "lines": [
          "Год — людям надежда,",
          "если Бог позволит,",
          "святой небесный конунг,",
          "земле дать",
          "славные плоды",
          "и благородным, и бедным."
        ],
        "placeholder": false
      },
      {
        "id": "15",
        "type": "stanza",
        "number": "13.",
        "lines": [
          "Тис снаружи —",
          "грубое дерево,",
          "стоек в земле и крепок,",
          "хранитель огня,",
          "корнями укреплен —",
          "радость вотчины."
        ],
        "placeholder": false
      },
      {
        "id": "16",
        "type": "stanza",
        "number": "14.",
        "lines": [
          "Peorþ — вечно",
          "игра и смех",
          "гордых (…),",
          "где бойцы сидят",
          "в пивном чертоге,",
          "счастливы вместе"
        ],
        "placeholder": false
      },
      {
        "id": "17",
        "type": "stanza",
        "number": "15.",
        "lines": [
          "Лось — осока живет",
          "чаще всего на болоте,",
          "растет в воде,",
          "ранит жестоко",
          "кровью красит",
          "человека каждого",
          "который ее, так или иначе,",
          "схватить дерзнет (?)."
        ],
        "placeholder": false
      },
      {
        "id": "18",
        "type": "stanza",
        "number": "16.",
        "lines": [
          "Солнце морякам",
          "всегда в радость,",
          "когда они идут",
          "над купальней рыб,",
          "пока морского скакуна",
          "к земле не приведут."
        ],
        "placeholder": false
      },
      {
        "id": "19",
        "type": "heading",
        "lines": [
          "Att III"
        ],
        "placeholder": false
      },
      {
        "id": "20",
        "type": "stanza",
        "number": "17.",
        "lines": [
          "Тир — некое знамение.",
          "Хранит ряд хорошо",
          "с этелингами.",
          "Вечно в пути",
          "над ночной мглой,",
          "никогда не обманет."
        ],
        "placeholder": false
      },
      {
        "id": "21",
        "type": "stanza",
        "number": "18.",
        "lines": [
          "Береза лишена цветов,",
          "но рождает даже так",
          "побеги бесплодные,",
          "ветвями красива,",
          "высока кроной,",
          "украшенной дивно,",
          "нагруженной листьями,",
          "к небу близкой."
        ],
        "placeholder": false
      },
      {
        "id": "22",
        "type": "stanza",
        "number": "19.",
        "lines": [
          "Конь перед эрлами —",
          "этелингов радость,",
          "конь копытами горд —",
          "когда о нем герои",
          "богатые на скакунах",
          "обмениваются речами.",
          "И беспокойным он —",
          "всегда утешенье"
        ],
        "placeholder": false
      },
      {
        "id": "23",
        "type": "stanza",
        "number": "20.",
        "lines": [
          "Человек — счастлив,",
          "родне своей люб,",
          "но должен каждый",
          "прочих покинуть",
          "потому, что волей Господа,",
          "его повелением,",
          "эта жалкая плоть",
          "земле будет предана"
        ],
        "placeholder": false
      },
      {
        "id": "24",
        "type": "stanza",
        "number": "21.",
        "lines": [
          "Море — людям",
          "бесконечным мыслится",
          "если они должны пуститься",
          "на ладье неустойчивой",
          "и волны морские",
          "их сильно страшат",
          "и морской жеребец",
          "узде неподвластен."
        ],
        "placeholder": false
      },
      {
        "id": "25",
        "type": "stanza",
        "number": "22.",
        "lines": [
          "Инг 6 был первым",
          "среди восточных данов",
          "увиденный людьми,",
          "пока он вновь",
